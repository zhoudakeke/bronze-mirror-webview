      "type": "motif",
      "iconKey": "iconPrimary",
      "summary": "葡萄纹既是装饰元素，也是理解唐代文化交流的重要入口。",
      "detail": "葡萄经丝绸之路传入中原，唐代铜镜将其与海兽组合，象征丰饶与祥瑞。",
      "hotspotIds": ["grape"],
      "relatedMirrors": ["M001"]
    },
    {
      "id": "node-sea-beast",
      "label": "海兽纹",
      "type": "motif",
      "iconKey": "iconAlt",
